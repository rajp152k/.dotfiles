{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode",
  ],
  "model": "openrouter/google/gemini-3.1-flash-lite-preview",
  "small_model": "openrouter/google/gemini-3.1-flash-lite-preview",
  "autoupdate": true,
  "share": "manual",
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  "mcp": {
    "n8n": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--env-file",
        "/Users/nilenso/source/ops/secrets/n8n-mcp.env",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ],
      "enabled": true
    }
  }
}
